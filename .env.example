# ── COPY THIS FILE ───────────────────────────────────────────────────────────
# Local dev  →  copy to .env.local  (leave NEXT_PUBLIC_SOCKET_URL blank)
# Vercel     →  set these in Vercel Dashboard → Settings → Environment Variables
# Render     →  set ALLOWED_ORIGIN in Render Dashboard → Environment

# ── Next.js (Vercel) ─────────────────────────────────────────────────────────
# URL of your Render socket server.
# Leave blank for local dev (server.js handles both on same port).
NEXT_PUBLIC_SOCKET_URL=https://your-render-service.onrender.com

# ── Socket server (Render) ───────────────────────────────────────────────────
# Your Vercel frontend URL — restricts who can connect to the socket server.
ALLOWED_ORIGIN=https://your-app.vercel.app

PORT=4000
NODE_ENV=production
